# ---- Plaid (backend only — NEVER ship these to the mobile app) ----
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox                 # sandbox | development | production
PLAID_WEBHOOK_URL=                # public https URL the API exposes for Plaid webhooks
PLAID_PRODUCTS=transactions
PLAID_COUNTRY_CODES=US

# ---- Token encryption (backend) ----
# 32-byte key, base64-encoded. Generate: openssl rand -base64 32
ACCESS_TOKEN_ENC_KEY=

# ---- Supabase ----
SUPABASE_URL=
SUPABASE_ANON_KEY=                # safe for the mobile client
SUPABASE_SERVICE_ROLE_KEY=        # backend only — full DB access, never on client
DATABASE_URL=                     # Postgres connection string for Prisma

# ---- API ----
API_PORT=3333

# ---- Mobile (Expo public env — only non-secret values, prefixed EXPO_PUBLIC_) ----
EXPO_PUBLIC_API_URL=http://localhost:3333
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
